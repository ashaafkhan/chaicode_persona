ng-[-0.022em] focus-visible:outline-2 focus-visible:outline-offset-1 focus-visible:outline-transparent" type="button" aria-expanded="false" data-state="closed" data-orientation="vertical" id="radix-_r_12_" data-radix-collection-item="" style="border-radius: 28px; pointer-events: auto; opacity: 1;"><span class="flex-1 truncate font-montserrat text-xl font-medium sm:pb-1">Bonus</span><svg stroke="currentColor" fill="currentColor" stroke-width="0" viewBox="0 0 512 512" class="size-3 sm:mb-1" aria-hidden="true" height="1em" width="1em" xmlns="http://www.w3.org/2000/svg"><path d="M233.4 406.6c12.5 12.5 32.8 12.5 45.3 0l192-192c12.5-12.5 12.5-32.8 0-45.3s-32.8-12.5-45.3 0L256 338.7 86.6 169.4c-12.5-12.5-32.8-12.5-45.3 0s-12.5 32.8 0 45.3l192 192z"></path></svg></button></div></div></div></div></div><div class="mt-16 mb-8 flex w-full flex-col justify-center sm:mt-36 sm:items-center"><h2 class="text-[28px] font-light text-neutral-900 sm:text-center sm:text-4xl md:text-5xl dark:text-neutral-100">Meet your <span class="font-montserrat font-medium tracking-tight text-yellow-800 capitalize dark:text-orange-100">Instructors</span></h2><p class="mt-1 mb-3 max-w-4xl font-onest font-light sm:mt-5 sm:mb-10 sm:text-center sm:text-xl">Learn from <span class="font-medium">Industry Veterans</span> and <span class="font-medium">Guest Experts</span> who bring real-world experience<span class="max-sm:hidden"> to the classroom. Our instructors are passionate about teaching and committed to your success</span>.</p><div class="flex w-full max-w-4xl flex-col md:flex-row md:gap-8 lg:gap-12"><div class="hidden flex-col justify-end pt-4 pb-8 md:flex md:flex-1"><div class="flex-1"><button aria-label="View Hitesh Choudhary" class="size-20 cursor-pointer rounded-full ring-offset-2 transition-all duration-300 dark:ring-offset-black scale-110 ring-1 ring-orange-300 dark:ring-amber-700" type="button"><img class="size-20 rounded-full object-cover z-1" alt="Hitesh Choudhary profile" src="./pg black_files/hc-CSQ4zr-Q.jpg"></button><button aria-label="View Piyush Garg" class="size-20 cursor-pointer rounded-full ring-offset-2 transition-all duration-300 dark:ring-offset-black opacity-60 hover:opacity-90" type="button"><img class="size-20 rounded-full object-cover -z-1" alt="Piyush Garg profile" src="./pg black_files/piyush-BGToLlWT.jpg"></button></div><div class="space-y-6"><h2 class="mb-4 font-onest text-3xl font-medium tracking-tight text-gray-900 lg:text-4xl dark:text-white">Hitesh Choudhary</h2><p class="text-base leading-relaxed text-gray-700 lg:text-lg dark:text-gray-300">My hallmark is making the toughest topics easy to understand, a skill that has earned me a dedicated following. I am committed to educating and inspiring a diverse audience worldwide, making complex subjects accessible and engaging.</p><div class="flex items-center gap-4"><a href="https://www.youtube.com/@chaiaurcode" target="_blank" rel="noopener noreferrer" class="flex size-10 items-center justify-center rounded-full bg-neutral-50 transition-colors hover:bg-transparent dark:bg-neutral-900 hover:dark:bg-transparent" aria-label="Youtube"><svg stroke="currentColor" fill="currentColor" stroke-width="0" viewBox="0 0 576 512" class="size-5 text-neutral-700 hover:text-orange-500 dark:text-neutral-300 hover:dark:text-orange-400" aria-hidden="true" height="1em" width="1em" xmlns="http://www.w3.org/2000/svg"><path d="M549.655 124.083c-6.281-23.65-24.787-42.276-48.284-48.597C458.781 64 288 64 288 64S117.22 64 74.629 75.486c-23.497 6.322-42.003 24.947-48.284 48.597-11.412 42.867-11.412 132.305-11.412 132.305s0 89.438 11.412 132.305c6.281 23.65 24.787 41.5 48.284 47.821C117.22 448 288 448 288 448s170.78 0 213.371-11.486c23.497-6.321 42.003-24.171 48.284-47.821 11.412-42.867 11.412-132.305 11.412-132.305s0-89.438-11.412-132.305zm-317.51 213.508V175.185l142.739 81.205-142.739 81.201z"></path></svg></a><a href="http://linkedin.com/in/hiteshchoudhary" target="_blank" rel="noopener noreferrer" class="flex size